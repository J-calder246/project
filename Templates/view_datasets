                <td>{{ item['tract_population'] }}</td>
                <td>{{ item['tract_minority_population_percent'] }}</td>
                <td>{{ item['ffiec_msa_md_median_family_income'] }}</td>
                <td>{{ item['tract_to_msa_income_percentage'] }}</td>
                <td>{{ item['tract_owner_occupied_units'] }}</td>
                <td>{{ item['tract_one_to_four_family_homes'] }}</td>
                tract_median_age_of_housing_units'] }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    <a href="/upload">Upload Another CSV</a>
