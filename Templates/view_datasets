                <td>{{ item['co-applicant_race-3'] }}</td>
                <td>{{ item['co-applicant_race-4'] }}</td>
                <td>{{ item['co-applicant_race-5'] }}</td>
                <td>{{ item['applicant_race_observed'] }}</td>
                <td>{{ item['co-applicant_race_observed'] }}</td>
                <td>{{ item['applicant_sex'] }}</td>
                <td>{{ item['co-applicant_sex'] }}</td>
