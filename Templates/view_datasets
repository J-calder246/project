                <td>{{ item['loan_to_value_ratio'] }}</td>
                <td>{{ item['interest_rate'] }}</td>
                <td>{{ item['rate_spread'] }}</td>
                <td>{{ item['hoepa_status'] }}</td>
                <td>{{ item['total_loan_costs'] }}</td>
                <td>{{ item['total_points_and_fees'] }}</td>
                <td>{{ item['origination_charges'] }}</td>
                <td>{{ item['discount_points'] }}</td>
