                <td>{{ item['applicant_ethnicity-4'] }}</td>
                <td>{{ item['applicant_ethnicity-5'] }}</td>
                <td>{{ item['co-applicant_ethnicity-1'] }}</td>
                <td>{{ item['co-applicant_ethnicity-2'] }}</td>
                <td>{{ item['co-applicant_ethnicity-3'] }}</td>
                <td>{{ item['co-applicant_ethnicity-4'] }}</td>
                <td>{{ item['co-applicant_ethnicity-5'] }}</td>
                <td>{{ item['applicant_ethnicity_observed'] }}</td>
                <td>{{ item['co-applicant_ethnicity_observed'] }}</td>
                <td>{{ item['applicant_race-1'] }}</td>
